# WildArk Discord Builder Configuration

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Guild ID (Server ID where the bot will operate)
GUILD_ID=your_guild_id_here

# Client ID (Application ID from Discord Developer Portal)
CLIENT_ID=your_client_id_here

# Admin Role Name (for setup command permission)
ADMIN_ROLE_NAME=Founder

# WildArk Branding Colors (Hex)
PRIMARY_COLOR=0x9333EA
SECONDARY_COLOR=0x000000
ACCENT_COLOR=0xA855F7

# Ticket System Settings
TICKET_CATEGORY_NAME=📫 Support Tickets
MAX_TICKETS_PER_USER=3

# Welcome Channel
WELCOME_CHANNEL_NAME=👋-üdvözlés

# Log Channel
LOG_CHANNEL_NAME=📋-staff-logs


# ============================================================
# ARK Szerver Státusz Monitor (game-server query, nem Discord)
# ============================================================
# A QUERY PORT NEM ugyanaz mint a game port! A Nitrado/hoszting
# admin paneljeden találod (ASA alapban: game port 7777,
# query port 27015). Ha nem tudod, kérdezd meg a hosztingot.
#
# Ha egy szervernek nincs meg a host/port adata, hagyd üresen -
# a bot azt a szervert "ismeretlen" státusszal jelzi.

# Primal Chaos szerver
CHAOS_SERVER_HOST=
CHAOS_SERVER_QUERY_PORT=27015

# Primal Descended szerver
DESCENDED_SERVER_HOST=
DESCENDED_SERVER_QUERY_PORT=27015

# Tides of Fortune szerver
TIDES_SERVER_HOST=
TIDES_SERVER_QUERY_PORT=27015

# Státusz frissítési gyakoriság (percben, alap: 1 perc)
SERVER_STATUS_REFRESH_MINUTES=1

# Státusz csatorna neve
SERVER_STATUS_CHANNEL_NAME=📊-szerver-státusz
